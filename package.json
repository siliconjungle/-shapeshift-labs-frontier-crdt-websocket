{
  "name": "@shapeshift-labs/frontier-crdt-websocket",
  "version": "0.1.2",
  "description": "WebSocket client and server transports for Frontier CRDT sync providers.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/siliconjungle/-shapeshift-labs-frontier-crdt-websocket.git"
  },
  "homepage": "https://github.com/siliconjungle/-shapeshift-labs-frontier-crdt-websocket#readme",
  "bugs": {
    "url": "https://github.com/siliconjungle/-shapeshift-labs-frontier-crdt-websocket/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "import": "./dist/wire.js",
      "default": "./dist/wire.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "wire": [
        "./dist/wire.d.ts"
      ],
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE",
    "benchmarks/package-bench.mjs"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@shapeshift-labs/frontier-crdt-sync": "^0.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@shapeshift-labs/frontier-crdt": "^0.1.0",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "npm run build && npm run typecheck && node test/smoke.mjs && node test/integration.mjs && node test/fuzz.mjs --cases 80",
    "integration": "npm run build && node test/integration.mjs",
    "prepack": "npm run test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fuzz": "npm run build && node test/fuzz.mjs",
    "bench": "npm run build && node benchmarks/package-bench.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "frontier",
    "crdt",
    "sync",
    "websocket",
    "collaboration",
    "local-first"
  ]
}
